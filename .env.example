# ── Database (Neon Postgres) ─────────────────────────────────────────────────
# Pooled URL (application) — uses PgBouncer, NullPool required
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz-pooler.us-east-2.aws.neon.tech/dbname
# Direct URL (Alembic migrations only — bypasses PgBouncer)
MIGRATION_DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz.us-east-2.aws.neon.tech/dbname

# ── Crypto ───────────────────────────────────────────────────────────────────
# HMAC pepper: seeds all PRNG for watermark position/hopping. Changing this
# invalidates ALL previously signed content. Rotate only at major version bump.
KERNEL_SYSTEM_PEPPER=changeme-use-a-32-byte-hex-string-in-production

# ── Queue (Valkey / Redis) ───────────────────────────────────────────────────
# When running the app via `uv run` against Docker services: REDIS_HOST=localhost
# When the app runs inside Docker on kernel_internal network: REDIS_HOST=valkey
REDIS_HOST=localhost
REDIS_PORT=6379
# Must be >= 32 chars — same value used as --requirepass in the Valkey container.
# Generate: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_SSL=false
# Optional: override Valkey memory cap (default: 512mb).
# Increase for high job throughput (200+ concurrent ARQ results stored in Redis).
REDIS_MAXMEMORY=512mb

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=s3             # local | s3
STORAGE_LOCAL_BASE_PATH=./data/media   # only used when STORAGE_BACKEND=local
# HMAC secret for signed download URLs (local storage only).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_HMAC_SECRET=change_in_production

# MinIO (local dev S3-compatible storage) ────────────────────────────────────
# Must NOT be "minioadmin" — validated by scripts/validate_env.sh before service start.
MINIO_ROOT_USER=kernel
# Must be >= 32 chars. Generate: openssl rand -base64 32
MINIO_ROOT_PASSWORD=

# S3-compatible storage (MinIO dev / Cloudflare R2 prod) ─────────────────────
# When app runs via `uv run` against local Docker: S3_ENDPOINT_URL=http://localhost:9000
# When app runs inside Docker on kernel_internal network: S3_ENDPOINT_URL=http://minio:9000
S3_ENDPOINT_URL=http://localhost:9000
# For local MinIO: S3_ACCESS_KEY_ID = MINIO_ROOT_USER, S3_SECRET_ACCESS_KEY = MINIO_ROOT_PASSWORD
S3_ACCESS_KEY_ID=kernel
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=kernel-media    # must match what createbucket creates
S3_REGION=us-east-1

# Cloudflare R2 (production) — set S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# and populate all S3_* vars above with R2 credentials. Leave S3_REGION=auto for R2.

# ── App ──────────────────────────────────────────────────────────────────────
ENV=development                # development | production
LOG_LEVEL=INFO
SENTRY_DSN=                    # leave blank to disable Sentry locally
CORS_ORIGINS=["http://localhost:3000"]

# ── Auth (Stack Auth / Neon Auth) ────────────────────────────────────────────
NEON_AUTH_URL=https://api.stack-auth.com
NEON_AUTH_API_KEY=             # Stack Auth project ID
NEON_AUTH_PUBLISHABLE_KEY=     # pck_...
NEON_AUTH_SECRET_SERVER_KEY=   # ssk_...

# ── Local admin (alternative to Stack Auth) ──────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=
# HS256 secret for local admin JWTs. Generate: openssl rand -hex 32
JWT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@notifications.kernelsecurity.tech

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000
