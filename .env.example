# ── Database (Neon Postgres) ─────────────────────────────────────────────────
# Pooled URL (application) — uses PgBouncer, NullPool required
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz-pooler.us-east-2.aws.neon.tech/dbname
# Direct URL (Alembic migrations only — bypasses PgBouncer)
MIGRATION_DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz.us-east-2.aws.neon.tech/dbname

# ── Crypto ───────────────────────────────────────────────────────────────────
# HMAC pepper: seeds all PRNG for watermark position/hopping. Changing this
# invalidates ALL previously signed content. Rotate only at major version bump.
KERNEL_SYSTEM_PEPPER=changeme-use-a-32-byte-hex-string-in-production

# ── Queue (Upstash Redis) ... → # ── Queue (Valkey / Redis) ...
REDIS_HOST=your-endpoint.upstash.io → REDIS_HOST=localhost
REDIS_PASSWORD=your-upstash-password → REDIS_PASSWORD=
REDIS_SSL=true → REDIS_SSL=false

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | r2 (r2 available in H1)
STORAGE_LOCAL_BASE_PATH=./data/media   # only used when STORAGE_BACKEND=local

# Cloudflare R2 — leave blank for local development
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── App ──────────────────────────────────────────────────────────────────────
ENV=development                # development | production
LOG_LEVEL=INFO
SENTRY_DSN=                    # leave blank to disable Sentry locally
